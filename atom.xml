    <title>Python小结--列表</title>
    <link href="https://allure-luv.github.io/2021/08/07/Python%E5%B0%8F%E7%BB%93-%E5%88%97%E8%A1%A8/"/>
    <id>https://allure-luv.github.io/2021/08/07/Python%E5%B0%8F%E7%BB%93-%E5%88%97%E8%A1%A8/</id>
